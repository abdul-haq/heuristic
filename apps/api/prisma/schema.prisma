// Heuristic database schema
//
// Notes:
// - Embedding columns use the `Unsupported("vector(384)")` type because
//   Prisma doesn't have native pgvector support yet. 384 = bge-small-en dim.
// - We enable the pgvector extension via a manual migration step.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cvVariants   CVVariant[]
  bullets      CVBullet[]
  jds          JobDescription[]
  applications Application[]
  llmCalls     LLMCall[]
}

model CVVariant {
  id        String   @id @default(cuid())
  userId    String
  name      String   // "Base", "Full-Stack", "Frontend", "PHP"
  slug      String   // "base", "full-stack", ...
  createdAt DateTime @default(now())

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  bullets CVBullet[]

  @@unique([userId, slug])
}

model CVBullet {
  id        String  @id @default(cuid())
  userId    String
  variantId String?

  // Where this bullet belongs in the CV
  section  String // "experience" | "project" | "education"
  company  String? // "Atompoint", "Cigul", ...
  role     String? // "Full-Stack Developer"
  ordering Int     @default(0)

  // The content
  text   String
  // Skills tagged on this bullet — drives keyword matching
  skills String[] // ["react", "node.js", "postgres"]
  // Category for filtering
  category String? // "backend" | "frontend" | "devops" | "team" | "perf"

  // Embedding for semantic retrieval. Generated by Transformers.js.
  // 384 dimensions matches bge-small-en.
  embedding Unsupported("vector(384)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant CVVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
}

model JobDescription {
  id     String @id @default(cuid())
  userId String

  // Source
  sourceUrl String?
  platform  String? // "linkedin" | "stepstone" | "indeed" | "manual"

  // Extracted by LLM
  companyName String?
  roleTitle   String?
  location    String?
  language    String? // "en" | "de"
  germanLevel String? // "none" | "a1" | "a2" | "b1" | "b2" | "c1"
  workFormat  String? // "werkstudent" | "internship" | "fulltime"
  rawText     String  @db.Text

  // Structured extraction result (kept as JSON for flexibility)
  extracted Json? // { mustHaves, niceToHaves, salary, etc. }

  // Embedding of the JD text for similarity search
  embedding Unsupported("vector(384)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]
}

model Application {
  id     String @id @default(cuid())
  userId String
  jdId   String

  status      String   @default("captured") // captured | applied | follow_up | interview | rejected | offer
  matchScore  Int?     // 0-100
  notes       String?  @db.Text
  appliedAt   DateTime?
  followUpAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  jd   JobDescription @relation(fields: [jdId], references: [id], onDelete: Cascade)
}

model LLMCall {
  id           String   @id @default(cuid())
  userId       String?
  provider     String   // "ollama" | "anthropic"
  model        String
  taskType     String   // "extract_jd" | "rewrite_bullet" | "draft_letter" | ...
  inputTokens  Int?
  outputTokens Int?
  costCents    Float    @default(0)
  latencyMs    Int?
  success      Boolean  @default(true)
  errorMessage String?
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([taskType, createdAt])
}
